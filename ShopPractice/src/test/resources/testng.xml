<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite">
   <!-- Listener for Extent Report -->
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <!-- Module 1: Login -->
    <test name="Login Module Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <!-- Module 2: Product -->
    <test name="Product Module Tests">
        <classes>
            <class name="tests.ProductTest"/>
        </classes>
    </test>

    <!-- Module 3: Cart -->
    <test name="Cart Module Tests">
        <classes>
            <class name="tests.CartTest"/>
        </classes>
    </test>

    <!-- Module 4: Order -->
    <test name="Order Module Tests">
        <classes>
            <class name="tests.OrderTest"/>
        </classes>
    </test> <!-- Test -->
</suite> <!-- Suite -->
